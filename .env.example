# ─────────────────────────────────────────────
# ProfitEngine v4.0 — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Core
PORT=3000
NODE_ENV=production
BUSINESS_NAME=Already Here LLC
SITE_DOMAIN=alreadyherellc.com
CONTACT_EMAIL=alreadyherellc@gmail.com
LOG_LEVEL=info

# Dashboard Auth (leave blank to disable auth)
DASH_USER=admin
DASH_PASS=yourpassword

# Content Strategy
TARGET_NICHES=passive income,ai tools,side hustle,print on demand,affiliate marketing
AFFILIATE_PRODUCTS=ring light,tripod,microphone,laptop stand,canva pro,web hosting
SCAN_INTERVAL_MINUTES=15
MAX_POSTS_PER_DAY=20
CONTENT_PER_RUN=3

# LLM (at least one required)
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# GitHub (required for website publishing)
GITHUB_TOKEN=
GITHUB_OWNER=quantam101
GITHUB_REPO=already-here-llc
GITHUB_BLOG_DIR=posts

# Blog Platforms
DEVTO_API_KEY=
HASHNODE_API_KEY=
HASHNODE_PUBLICATION_ID=
MEDIUM_API_KEY=
MEDIUM_AUTHOR_ID=

# Social
MASTODON_ACCESS_TOKEN=
MASTODON_INSTANCE=mastodon.social
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Affiliate
AMAZON_PARTNER_TAG=alreadyhere-20

# Print-on-Demand
PRINTIFY_API_KEY=
PRINTIFY_SHOP_ID=

# Email Alerts
GMAIL_USER=alreadyherellc@gmail.com
GMAIL_APP_PASSWORD=
ALERT_EMAIL=alreadyherellc@gmail.com

# UltraFlow VHLL
ULTRAFLOW_URL=
ULTRAFLOW_API_KEY=
